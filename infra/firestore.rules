rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCreate() {
      return request.resource.data.keys().size() > 0
        && !exists(resource);
    }

    function isUpdate() {
      return exists(resource);
    }

    function onlyAllowedFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function immutable(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == resource.data[field];
    }

    function isValidLatestAnalysis(data) {
      return data is map
        && data.keys().hasOnly([
          'fitScore',
          'ghostingRisk',
          'urgencyLevel',
          'tacticalSignal',
          'matchAnalysis',
          'keyMatches',
          'missingKeywords',
          'suggestedImprovements',
          'analyzedAt'
        ])
        && (!('fitScore' in data) || (data.fitScore is number && data.fitScore >= 0 && data.fitScore <= 100))
        && (!('ghostingRisk' in data) || (data.ghostingRisk is number && data.ghostingRisk >= 0 && data.ghostingRisk <= 100))
        && (!('urgencyLevel' in data) || (data.urgencyLevel is number && data.urgencyLevel >= 0 && data.urgencyLevel <= 100))
        && (!('tacticalSignal' in data) || (data.tacticalSignal is string && data.tacticalSignal.size() <= 200))
        && (!('matchAnalysis' in data) || (data.matchAnalysis is string && data.matchAnalysis.size() <= 5000))
        && (!('keyMatches' in data) || (data.keyMatches is list && data.keyMatches.size() <= 50))
        && (!('missingKeywords' in data) || (data.missingKeywords is list && data.missingKeywords.size() <= 50))
        && (!('suggestedImprovements' in data) || (data.suggestedImprovements is list && data.suggestedImprovements.size() <= 50))
        && (!('analyzedAt' in data) || (data.analyzedAt is string && data.analyzedAt.size() <= 40));
    }

    function isValidUserSettings(data) {
      return data is map
        && data.keys().hasOnly([
          'emailNotifications'
        ])
        && (!('emailNotifications' in data) || data.emailNotifications is bool);
    }

    function isValidApplicationData(data) {
      return data.company is string
        && data.company.size() > 0
        && data.company.size() <= 100
        && data.role is string
        && data.role.size() > 0
        && data.role.size() <= 100
        && data.status in [
          'Applied', 'Phone Screen', 'Technical Interview',
          'Final Round', 'Offer', 'Rejected'
        ]
        && data.dateApplied is string
        && data.dateApplied.size() == 10
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000))
        && (!('resumeUrl' in data) || (data.resumeUrl is string && data.resumeUrl.size() <= 1000))
        && (!('visaSponsorship' in data) || data.visaSponsorship is bool)
        && (!('requestAnalysis' in data) || data.requestAnalysis is bool)
        && (!('latestAnalysis' in data) || isValidLatestAnalysis(data.latestAnalysis))
        && (!('userId' in data) || data.userId == request.auth.uid);
    }

    // User profile documents
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && onlyAllowedFields([
          'email', 'displayName', 'photoURL', 'createdAt', 'settings', 'defaultResume'
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 120))
        && (!('photoURL' in request.resource.data)
            || (request.resource.data.photoURL is string
                && request.resource.data.photoURL.size() <= 1000))
        && (!('settings' in request.resource.data)
            || isValidUserSettings(request.resource.data.settings))
        && request.resource.data.createdAt is timestamp
        && (!('defaultResume' in request.resource.data)
            || (request.resource.data.defaultResume is string
                && request.resource.data.defaultResume.size() <= 50000));

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys()
           .hasOnly(['settings', 'defaultResume', 'displayName', 'photoURL'])
        && immutable('createdAt')
        && (!('displayName' in request.resource.data)
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() <= 120))
        && (!('photoURL' in request.resource.data)
            || (request.resource.data.photoURL is string
                && request.resource.data.photoURL.size() <= 1000))
        && (!('settings' in request.resource.data)
            || isValidUserSettings(request.resource.data.settings))
        && (!('defaultResume' in request.resource.data)
            || (request.resource.data.defaultResume is string
                && request.resource.data.defaultResume.size() <= 50000));

      allow delete: if false; // Users cannot delete their own profile
    }

    // Applications subcollection
    match /users/{userId}/applications/{applicationId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && onlyAllowedFields([
          'company', 'role', 'status', 'dateApplied', 'notes',
          'resumeUrl', 'visaSponsorship', 'createdAt', 'updatedAt',
          'requestAnalysis', 'userId', 'latestAnalysis'
        ])
        && isValidApplicationData(request.resource.data)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys()
           .hasOnly([
             'company',
             'role',
             'status',
             'dateApplied',
             'notes',
             'resumeUrl',
             'visaSponsorship',
             'updatedAt',
             'requestAnalysis',
             'latestAnalysis'
           ])
        && isValidApplicationData(request.resource.data)
        && request.resource.data.updatedAt is timestamp
        && immutable('createdAt')
        && immutable('userId');

      allow delete: if isOwner(userId);
    }

    // AI Analysis subcollection (server-only writes)
    match /users/{userId}/aiAnalysis/{analysisId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write AI results
    }

    // Weekly Analytics subcollection (server-only writes)
    match /users/{userId}/weeklyAnalytics/{weekId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write analytics
    }

    // Global analytics (future use - admin only)
    match /globalAnalytics/{metricId} {
      allow read: if false; // No public access
      allow write: if false; // Admin only via Cloud Functions
    }

    // Default deny - security best practice
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
